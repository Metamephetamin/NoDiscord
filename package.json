{
  "name": "tend",
  "productName": "Tend",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "dev:frontend": "vite --config vite.renderer.config.mjs",
    "start:backend": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-backend.ps1",
    "start:livekit": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-livekit.ps1",
    "start:livekit:docker": "docker compose --env-file .env -f src/livekit/docker-compose.yml up -d --force-recreate",
    "build": "npm run build:frontend",
    "build:frontend": "vite build --config vite.renderer.config.mjs",
    "build:hosting": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-hosting-bundle.ps1",
    "package": "electron-forge package",
    "package:prod": "node ./scripts/run-with-runtime.mjs package",
    "make": "electron-forge make",
    "make:prod": "node ./scripts/run-with-runtime.mjs make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --quiet",
    "check:encoding": "node ./scripts/check-encoding.mjs",
    "check:encoding:fix": "node ./scripts/check-encoding.mjs --fix",
    "test:encoding": "node --test ./scripts/__tests__/encoding-tools.test.mjs",
    "audit:public-assets": "node ./scripts/audit-public-assets.mjs",
    "audit:perf": "node ./scripts/perf-audit.mjs"
  },
  "keywords": [],
  "author": {
    "name": "Andrey",
    "email": "andrey1689123@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.8.3",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron-forge/plugin-vite": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "electron": "39.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^7.2.6"
  },
  "dependencies": {
    "@microsoft/signalr": "^9.0.6",
    "@microsoft/signalr-protocol-msgpack": "^10.0.0",
    "@shiguredo/noise-suppression": "^2025.1.0",
    "@vitejs/plugin-react": "^5.1.0",
    "axios": "^1.13.1",
    "electron-squirrel-startup": "^1.0.1",
    "howler": "^2.2.4",
    "leaflet": "^1.9.4",
    "livekit-client": "^2.18.1",
    "openai": "^6.34.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-player": "^3.4.0",
    "react-router-dom": "^7.9.5",
    "readline-sync": "^1.4.10"
  }
}
