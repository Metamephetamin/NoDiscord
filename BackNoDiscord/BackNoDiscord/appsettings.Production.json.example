{
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Port=5432;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS",
    "Issuer": "BackNoDiscord",
    "Audience": "BackNoDiscordUsers"
  },
  "Crypto": {
    "Key": "REPLACE_WITH_A_SEPARATE_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS"
  },
  "Email": {
    "Mode": "smtp",
    "FromAddress": "no-reply@your-domain.example",
    "FromName": "MAX",
    "Smtp": {
      "Host": "smtp.your-provider.example",
      "Port": 587,
      "Username": "smtp-user",
      "Password": "smtp-password",
      "EnableSsl": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
