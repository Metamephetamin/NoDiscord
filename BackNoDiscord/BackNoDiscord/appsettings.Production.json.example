{
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Port=5432;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS",
    "Issuer": "BackNoDiscord",
    "Audience": "BackNoDiscordUsers"
  },
  "Crypto": {
    "Key": "REPLACE_WITH_A_SEPARATE_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS"
  },
  "Email": {
    "Mode": "smtp",
    "FromAddress": "code@tendsec.ru",
    "FromName": "MAX",
    "Smtp": {
      "Host": "smtp.beget.com",
      "Port": 465,
      "Username": "code@tendsec.ru",
      "Password": "REPLACE_WITH_SMTP_PASSWORD",
      "EnableSsl": true
    }
  },
  "Auth": {
    "RequireEmailVerification": true
  },
  "Spotify": {
    "ClientId": "REPLACE_WITH_SPOTIFY_CLIENT_ID",
    "ClientSecret": "REPLACE_WITH_SPOTIFY_CLIENT_SECRET",
    "RedirectUri": "https://tendsec.ru/api/integrations/spotify/callback"
  },
  "GitHub": {
    "ClientId": "REPLACE_WITH_GITHUB_OAUTH_CLIENT_ID",
    "ClientSecret": "REPLACE_WITH_GITHUB_OAUTH_CLIENT_SECRET",
    "RedirectUri": "https://tendsec.ru/api/integrations/github/callback"
  },
  "Steam": {
    "ApiKey": "REPLACE_WITH_STEAM_WEB_API_KEY"
  },
  "BattleNet": {
    "ClientId": "REPLACE_WITH_BATTLENET_CLIENT_ID",
    "ClientSecret": "REPLACE_WITH_BATTLENET_CLIENT_SECRET",
    "RedirectUri": "https://tendsec.ru/api/integrations/battlenet/callback",
    "Region": "eu"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.your-domain.example",
      "https://api.your-domain.example"
    ]
  },
  "ClientUpdates": {
    "LatestVersion": "1.0.1",
    "MinimumVersion": "1.0.0",
    "AutoInstallOnQuit": true,
    "ReleaseNotes": "Фоновое обновление клиента и улучшения стабильности.",
    "Windows": {
      "X64": {
        "DownloadUrl": "https://downloads.your-domain.example/Tend%20Setup%201.0.1.exe",
        "Sha256": "REPLACE_WITH_SHA256_OF_THE_INSTALLER"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
