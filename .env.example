# Root frontend/backend local environment example
# Copy to `.env` locally and fill with your own values.

# Backend
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=voiceapp;Username=postgres;Password=change-me
Jwt__Key=replace-with-a-long-random-secret-at-least-32-characters
Jwt__Issuer=BackNoDiscord
Jwt__Audience=BackNoDiscordUsers
Jwt__AccessTokenMinutes=10080
Jwt__RefreshTokenDays=14
Crypto__Key=replace-with-a-separate-long-random-secret-at-least-32-characters
Email__Mode=mock
# For real SMTP instead of mock:
# Email__Mode=smtp
# Email__FromAddress=no-reply@example.com
# Email__FromName=MAX
# Email__Smtp__Host=smtp.example.com
# Email__Smtp__Port=587
# Email__Smtp__Username=your-smtp-login
# Email__Smtp__Password=your-smtp-password
# Email__Smtp__EnableSsl=true
# Web Push
# Generate a VAPID key pair and put values below for browser push notifications.
# WEBPUSH_SUBJECT=mailto:no-reply@example.com
# WEBPUSH_PUBLIC_KEY=replace-with-your-vapid-public-key
# WEBPUSH_PRIVATE_KEY=replace-with-your-vapid-private-key

# Electron / renderer runtime
ND_API_URL=http://localhost:7031
ND_LIVEKIT_URL=wss://localhost:5173/livekit
# Optional public browser app origin for invite links and explicit CORS allow-list.
# In production, set this if your frontend is opened from a different origin than the API.
ND_PUBLIC_APP_URL=https://tendsec.ru
# ND_ALLOWED_ORIGINS=https://app.example.com,https://api.example.com

# Voice privacy / TURN
# Use relay in production if you want to hide peer network details behind TURN.
ND_ICE_TRANSPORT_POLICY=all
# ND_STUN_URL=stun:stun.l.google.com:19302
# ND_TURN_URL=turn:turn.example.com:3478?transport=udp
# ND_TURN_USERNAME=turn-user
# ND_TURN_CREDENTIAL=turn-password
# Or configure all ICE servers explicitly as JSON:
# ND_ICE_SERVERS_JSON=[{"urls":"turn:turn.example.com:3478?transport=udp","username":"turn-user","credential":"turn-password"}]
#
# Browser/Vite runtime equivalents for the web app:
# VITE_ICE_TRANSPORT_POLICY=all
# VITE_STUN_URL=stun:stun.l.google.com:19302
# VITE_TURN_URL=turn:turn.example.com:3478?transport=udp
# VITE_TURN_USERNAME=turn-user
# VITE_TURN_CREDENTIAL=turn-password
# VITE_ICE_SERVERS_JSON=[{"urls":"turn:turn.example.com:3478?transport=udp","username":"turn-user","credential":"turn-password"}]

# LiveKit
LiveKit__Url=wss://localhost:5173/livekit
# Optional explicit credentials for backend token issuance:
# LiveKit__ApiKey=devkey
# LiveKit__ApiSecret=replace-with-your-own-livekit-secret
LIVEKIT_KEYS=devkey: replace-with-your-own-livekit-secret

# Client updates
# ClientUpdates__LatestVersion=1.0.1
# ClientUpdates__MinimumVersion=1.0.0
# ClientUpdates__AutoInstallOnQuit=true
# ClientUpdates__ReleaseNotes=Background update downloaded on startup and installed after app exit.
# ClientUpdates__Windows__X64__DownloadUrl=https://downloads.example.com/Tend%20Setup%201.0.1.exe
# ClientUpdates__Windows__X64__Sha256=replace-with-installer-sha256
